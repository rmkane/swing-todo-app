#!/usr/bin/env bash
# Pre-commit: Spotless formatting + compile (same checks as CI "Lint" step).
set -euo pipefail

if [[ "${SKIP_PRE_COMMIT:-}" == "1" ]]; then
	echo "pre-commit: skipped (SKIP_PRE_COMMIT=1)"
	exit 0
fi

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

if ! command -v mvn >/dev/null 2>&1; then
	echo "pre-commit: mvn not found on PATH" >&2
	exit 1
fi

echo "pre-commit: checking formatting (spotless)..."
mvn spotless:check -q

echo "pre-commit: compiling..."
mvn compile test-compile -q

echo "pre-commit: lint passed."
